# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=anomaly_detection

# ── MLflow ──
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=anomaly-detection

# ── Isolation Forest ──
IF_N_ESTIMATORS=100
IF_CONTAMINATION=0.05
IF_RANDOM_STATE=42

# ── DBSCAN ──
DBSCAN_EPS=0.5
DBSCAN_MIN_SAMPLES=5
DBSCAN_METRIC=euclidean

# ── LSTM Autoencoder ──
LSTM_SEQ_LENGTH=30
LSTM_HIDDEN_DIM=64
LSTM_NUM_EPOCHS=50
LSTM_LEARNING_RATE=0.001
LSTM_THRESHOLD_PERCENTILE=95.0

# ── Ensemble (Majority Voting) ──
ENSEMBLE_MIN_VOTES=2

# ── SHAP ──
SHAP_MAX_DISPLAY=20
SHAP_SAMPLE_SIZE=100

# ── Docker Service URLs ──
API_HOST=0.0.0.0
API_PORT=8000
MLFLOW_HOST=mlflow
MLFLOW_PORT=5000
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/anomaly_detection
